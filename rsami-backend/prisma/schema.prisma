generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum SeatStatus {
  AVAILABLE
  LOCKED
  BOOKED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password_hash String
  role          Role      @default(CUSTOMER)
  created_at    DateTime  @default(now())
  bookings      Booking[]
}

model Movie {
  id               String   @id @default(uuid())
  title            String
  description      String
  language         String
  duration_minutes Int
  genre            String
  poster_url       String?
  trailer_url      String?
  is_active        Boolean  @default(true)
  shows            Show[]
}

model Show {
  id         String     @id @default(uuid())
  movie_id   String
  movie      Movie      @relation(fields: [movie_id], references: [id])
  show_date  DateTime
  start_time DateTime
  end_time   DateTime
  base_price Float
  show_seats ShowSeat[]
  bookings   Booking[]
}

model Seat {
  id         String     @id @default(uuid())
  row        String
  number     Int
  category   String     @default("standard")
  show_seats ShowSeat[]

  @@unique([row, number])
}

model ShowSeat {
  id           String        @id @default(uuid())
  show_id      String
  show         Show          @relation(fields: [show_id], references: [id])
  seat_id      String
  seat         Seat          @relation(fields: [seat_id], references: [id])
  status       SeatStatus    @default(AVAILABLE)
  locked_until DateTime?
  price        Float
  booking_item BookingItem[]

  @@unique([show_id, seat_id])
}

model Booking {
  id                String        @id @default(uuid())
  user_id           String
  user              User          @relation(fields: [user_id], references: [id])
  show_id           String
  show              Show          @relation(fields: [show_id], references: [id])
  status            BookingStatus @default(PENDING)
  total_amount      Float
  payment_intent_id String?
  created_at        DateTime      @default(now())
  booking_items     BookingItem[]
}

model BookingItem {
  id           String   @id @default(uuid())
  booking_id   String
  booking      Booking  @relation(fields: [booking_id], references: [id])
  show_seat_id String
  show_seat    ShowSeat @relation(fields: [show_seat_id], references: [id])

  @@unique([booking_id, show_seat_id])
}
